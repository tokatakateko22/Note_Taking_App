# LLM Provider Configuration
# Supported providers: gemini (default), groq, ollama
LLM_PROVIDER=groq

# Google Gemini API Settings (free tier via https://aistudio.google.com/apikey)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-2.0-flash

# Groq API Settings (free tier via https://console.groq.com/keys)
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE
GROQ_MODEL=llama-3.1-8b-instant

# Ollama Settings (local fallback — optional)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Database Configuration
DB_PATH=./notes.db
DEFAULT_USER_ID=default

# Semantic Search Embeddings Configuration
EMBEDDING_MODEL=all-MiniLM-L6-v2
SEMANTIC_THRESHOLD=0.35
